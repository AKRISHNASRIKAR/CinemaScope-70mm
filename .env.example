# TMDB API
VITE_API_KEY=TMDB_API_KEY
VITE_BASE_URL=https://api.themoviedb.org/3

# Auth0 — get these from your Auth0 tenant's application settings
# Current credentials in .env:
#   VITE_AUTH0_DOMAIN=dev-elsgrcg0i2krz68n.us.auth0.com
#   VITE_AUTH0_CLIENT_ID=oYr0qc7FBGOv5JRWO1aGcX47BlJi0rrI
#   VITE_AUTH0_AUDIENCE= (not set - using default Auth0 flow)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id
VITE_AUTH0_AUDIENCE=https://your-api-identifier

# External links
VITE_GITHUB_URL=https://github.com/YOUR_USERNAME
